---
const links = [
	{
		label: 'mariosales27@outlook.com',
		href: 'mailto:mariosales27@outlook.com',
		prefix: 'email',
	},
	{
		label: '/in/rodasos',
		href: 'https://linkedin.com/in/rodasos',
		prefix: 'linkedin',
	},
	{
		label: '/rodasos',
		href: 'https://github.com/rodasos',
		prefix: 'github',
	},
]
---

<section id='contacto' class='scroll-m-24 w-full'>

	<div class='flex items-center gap-4 mb-12'>
		<span class='font-mono text-accent text-sm'>05.</span>
		<h2 class='text-2xl font-bold text-white'>Contacto</h2>
		<div style='height: 1px; background: #1d3550; flex: 1;'></div>
	</div>

	<div style='background: #0c1a2c; border: 2px solid #1d3550; border-radius: 16px;' class='p-8 text-center space-y-6'>
		<div class='space-y-2'>
			<p class='font-mono text-muted text-sm'>// ¿tienes un proyecto en mente?</p>
			<h3 class='text-3xl font-bold text-white'>Hablemos.</h3>
			<p class='text-slate-400 max-w-md mx-auto text-sm leading-relaxed'>
				Estoy disponible para proyectos freelance, colaboraciones o simplemente para conversar sobre tecnología.
			</p>
		</div>

		<a
			href='mailto:mariosales27@outlook.com'
			style='background: #00d9ff; color: #060a0f;'
			class='inline-flex items-center gap-2 px-6 py-3 rounded-lg font-mono font-medium text-sm hover:opacity-90 active:scale-95 transition-all'>
			Escribirme un mensaje
			<svg class='size-4' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
				<path d='M5 12h14'></path><path d='m12 5 7 7-7 7'></path>
			</svg>
		</a>

		<div class='flex justify-center gap-6 pt-2'>
			{links.map((link) => (
				<a
					href={link.href}
					target={link.href.startsWith('mailto') ? undefined : '_blank'}
					rel={link.href.startsWith('mailto') ? undefined : 'noopener'}
					class='flex flex-col items-center gap-1 group'>
					<span class='font-mono text-xs text-muted group-hover:text-accent transition-colors'>{link.prefix}</span>
					<span class='text-xs text-slate-400 group-hover:text-accent transition-colors'>{link.label}</span>
				</a>
			))}
		</div>
	</div>

</section>

---
const projects = [
	{
		name: 'Kuentas',
		description: 'App móvil para la gestión de gastos compartidos, tanto en solitario como en grupos. Desarrollada completamente de forma individual, desde el backend hasta la interfaz móvil.',
		url: 'https://kuentas.vercel.app',
		github: null,
		stack: ['React Native', 'NestJS', 'PostgreSQL', 'TypeScript'],
		accent: '#00d9ff',
	},
	{
		name: 'Sistema de Cantos & Acordes',
		description: 'Aplicación web para la gestión del repertorio musical de un coro de iglesia. Permite organizar cantos, acordes y listas de reproducción para cada servicio.',
		url: null,
		github: null,
		stack: ['Next.js', 'TypeScript'],
		accent: '#7c3aed',
	},
	{
		name: 'Portal GBL',
		description: 'Portal web para Grupo GBL (Guatemala) con gestión de clientes, facturas y usuarios. Incluye landing pública y plataforma de administración privada.',
		url: 'https://grupogbl.net',
		github: null,
		stack: [],
		accent: '#00d9ff',
	},
]
---

<section id='proyectos' class='scroll-m-24 w-full'>

	<div class='flex items-center gap-4 mb-12'>
		<span class='font-mono text-accent text-sm'>03.</span>
		<h2 class='text-2xl font-bold text-white'>Proyectos</h2>
		<div style='height: 1px; background: #1d3550; flex: 1;'></div>
	</div>

	<div class='space-y-6'>
		{projects.map((project, i) => (
			<article style='background: #0c1a2c; border: 1px solid #1d3550; border-radius: 12px;' class='group p-6 hover:border-accent/50 transition-all hover:shadow-[0_0_40px_rgba(0,217,255,0.05)]'>
				<div class='flex flex-col md:flex-row md:items-start gap-6'>

					<!-- Placeholder imagen -->
					<div class='w-full md:w-64 md:shrink-0'>
						<div class='aspect-video rounded-lg border border-border overflow-hidden relative flex items-center justify-center'
							style={`background: linear-gradient(135deg, #0d1117 0%, #1e2d3d 100%)`}>
							<div class='absolute inset-0 opacity-15' style='background-image: radial-gradient(circle, #00d9ff 1px, transparent 1px); background-size: 18px 18px;'></div>
							<span class='font-mono text-xs relative z-10' style={`color: ${project.accent}; opacity: 0.7`}>
								{project.url ? project.url.replace('https://', '') : project.name.toLowerCase().replace(/ /g, '-')}
							</span>
						</div>
					</div>

					<!-- Info -->
					<div class='flex-1 space-y-3'>
						<div class='flex items-start justify-between gap-4'>
							<h3 class='text-xl font-bold text-white group-hover:text-accent transition-colors'>{project.name}</h3>
							<span class='font-mono text-xs text-muted shrink-0'>0{i + 1}</span>
						</div>

						<p class='text-slate-400 text-sm leading-relaxed'>{project.description}</p>

						{project.stack.length > 0 && (
							<div class='flex flex-wrap gap-2'>
								{project.stack.map((tech) => (
									<span style='border: 1px solid #1d3550; background: #060a0f;' class='px-2 py-0.5 text-xs font-mono text-muted rounded'>
										{tech}
									</span>
								))}
							</div>
						)}

						<div class='flex gap-3 pt-1'>
							{project.github && (
								<a href={project.github} target='_blank' rel='noopener'
									class='inline-flex items-center gap-1.5 text-xs font-mono text-muted hover:text-accent transition-colors'>
									<svg class='size-3.5' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
										<path d='M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 1.8 5.4 2.1 5.4 2.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 8.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21'></path>
									</svg>
									Código
								</a>
							)}
							{project.url && (
								<a href={project.url} target='_blank' rel='noopener'
									class='inline-flex items-center gap-1.5 text-xs font-mono text-accent hover:text-white transition-colors'>
									<svg class='size-3.5' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
										<path d='M15 3h6v6'></path><path d='M10 14 21 3'></path>
										<path d='M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6'></path>
									</svg>
									Ver proyecto
								</a>
							)}
						</div>
					</div>
				</div>
			</article>
		))}
	</div>

</section>
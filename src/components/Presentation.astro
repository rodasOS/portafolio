---
const stack = ['Angular', 'React', 'NestJS', 'TypeScript', '.NET', 'Laravel', 'React Native']
---

<section class='min-h-[calc(100vh-120px)] flex flex-col justify-center gap-8 mb-8'>

	<div>
		<a href='https://linkedin.com/in/rodasos' target='_blank' rel='noopener'
			class='inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full border border-accent/30 bg-accent/5 text-accent text-sm font-mono backdrop-blur-sm hover:border-accent/60 hover:bg-accent/10 transition-all'>
			<span class='w-2 h-2 rounded-full bg-accent animate-pulse'></span>
			disponible para trabajar
		</a>
	</div>

	<div class='space-y-3'>
		<p class='font-mono text-muted text-base'>// hola, soy</p>
		<h1 class='text-6xl md:text-8xl font-bold leading-none tracking-tight'>
			Mario <span class='text-transparent bg-clip-text' style='background-image: linear-gradient(135deg, #00d9ff, #7c3aed)'>Sales</span>
		</h1>
		<div class='flex items-center gap-2 mt-2'>
			<p class='text-2xl md:text-3xl text-slate-400 font-light'>Desarrollador Full Stack</p>
			<span class='inline-block w-0.5 h-7 bg-accent animate-blink'></span>
		</div>
	</div>

	<div class='flex flex-wrap gap-2 max-w-lg'>
		{stack.map((tech) => (
			<span class='px-3 py-1 text-xs font-mono border border-border text-muted bg-surface rounded-md hover:border-accent/40 hover:text-slate-200 transition-colors cursor-default'>
				{tech}
			</span>
		))}
	</div>

	<div class='flex flex-wrap gap-3'>
		<a
			href='https://github.com/rodasos'
			target='_blank'
			rel='noopener'
			class='inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-border bg-surface text-slate-300 hover:border-accent/40 hover:text-accent transition-all font-mono text-sm'>
			<svg class='size-4' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
				<path d='M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 1.8 5.4 2.1 5.4 2.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 8.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21'></path>
			</svg>
			/rodasos
		</a>
		<a
			href='https://linkedin.com/in/rodasos'
			target='_blank'
			rel='noopener'
			class='inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-border bg-surface text-slate-300 hover:border-accent/40 hover:text-accent transition-all font-mono text-sm'>
			<svg class='size-4' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
				<path d='M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z'></path>
				<rect x='2' y='9' width='4' height='12'></rect>
				<circle cx='4' cy='4' r='2'></circle>
			</svg>
			/in/rodasos
		</a>
		<a
			href='mailto:mariosales27@outlook.com'
			class='inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-accent/30 bg-accent/5 text-accent hover:bg-accent/10 hover:border-accent/60 transition-all font-mono text-sm'>
			<svg class='size-4' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
				<rect x='2' y='4' width='20' height='16' rx='2'></rect>
				<path d='m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7'></path>
			</svg>
			mariosales27@outlook.com
		</a>
	</div>

</section>